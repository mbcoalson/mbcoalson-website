---
interface Props {
  name: string;
  description: string;
  href: string;
  language?: string;
}
const { name, description, href, language } = Astro.props;
---
<div class="repo-card">
  <div class="repo-header">
    <h3><a href={href} target="_blank" rel="noopener">{name}</a></h3>
    {language && <span class="lang">{language}</span>}
  </div>
  <p>{description}</p>
</div>

<style>
  .repo-card {
    padding: var(--space-m) 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .repo-card:first-of-type { border-top: 1px solid var(--color-rule); }
  .repo-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  h3 { font-size: 1.2rem; }
  h3 a { color: var(--color-text); text-decoration: none; }
  h3 a:hover { color: var(--color-accent); }
  .lang {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  p { font-size: 0.95rem; color: var(--color-muted); }
</style>
